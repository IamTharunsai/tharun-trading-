# ============================================================
# APEX TRADER — Environment Variables
# Copy this to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
TRADING_MODE=paper   # paper | live

# ── DATABASE ────────────────────────────────────────────────
DATABASE_URL=postgresql://apex_user:apex_secure_pass_2024@localhost:5432/apex_trader

# ── REDIS ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AUTHENTICATION ──────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_openssl_rand_-base64_64
ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_-hex_32
OWNER_EMAIL=your@email.com
OWNER_PHONE=+1XXXXXXXXXX

# ── ANTHROPIC (Claude AI - All 10 Agents) ───────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX

# ── ALPACA (US Stocks) ──────────────────────────────────────
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Paper: https://paper-api.alpaca.markets | Live: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── BINANCE (Crypto) ────────────────────────────────────────
BINANCE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BINANCE_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── COINBASE (Crypto Backup) ────────────────────────────────
COINBASE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
COINBASE_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── MARKET DATA ─────────────────────────────────────────────
POLYGON_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXX
ALPHA_VANTAGE_API_KEY=XXXXXXXXXXXXXXXXXXXX
NEWSAPI_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FINNHUB_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── SUPABASE (Auth) ─────────────────────────────────────────
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── AWS ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=XXXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_REGION=us-east-1
AWS_S3_BUCKET=apex-trader-logs

# ── TWILIO (SMS Alerts) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── SENTRY (Monitoring) ─────────────────────────────────────
SENTRY_DSN=https://XXXXXXXXXXXX@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── FRONTEND ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── GUARDRAILS (Defaults — adjust to your risk tolerance) ───
MAX_RISK_PER_TRADE_PCT=1
STOP_LOSS_CRYPTO_PCT=3
STOP_LOSS_STOCKS_PCT=2
TAKE_PROFIT_PCT=6
MAX_POSITION_SIZE_PCT=10
DAILY_LOSS_LIMIT_PCT=5
WEEKLY_DRAWDOWN_LIMIT_PCT=10
MAX_DRAWDOWN_ALL_TIME_PCT=20
CASH_RESERVE_PCT=30
MAX_TRADES_PER_DAY=50
MIN_AGENT_CONFIDENCE=65
MIN_VOTES_TO_EXECUTE=7
