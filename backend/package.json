{
  "name": "apex-trader-backend",
  "version": "1.0.0",
  "description": "APEX TRADER - Autonomous Multi-Agent Trading Platform Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate --schema=./prisma/schema.prisma && npx tsc",
    "start": "node dist/index.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma",
    "setup:db": "npm run prisma:generate && npm run prisma:migrate && prisma db seed --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.1",
    "@anthropic-ai/sdk": "^0.24.0",
    "@bull-board/express": "^5.18.0",
    "@prisma/client": "5.10.0",
    "@supabase/supabase-js": "^2.38.4",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "ethers": "^6.16.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "otplib": "^12.0.1",
    "prisma": "5.10.0",
    "socket.io": "^4.7.4",
    "speakeasy": "^2.0.0",
    "twilio": "^5.0.1",
    "winston": "^3.12.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.19",
    "@types/node-cron": "^3.0.11",
    "@types/speakeasy": "^2.0.10",
    "@types/ws": "^8.5.10",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts",
    "schema": "./prisma/schema.prisma"
  }
}
