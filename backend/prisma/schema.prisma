// APEX TRADER - Prisma Database Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// OWNER AUTH
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  lastLogin    DateTime?
  sessionToken String?
  ipWhitelist  Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// TRADES
model Trade {
  id               String        @id @default(cuid())
  asset            String
  market           String
  type             TradeType
  entryPrice       Float
  exitPrice        Float?
  quantity         Float
  pnl              Float?
  pnlPct           Float?
  fees             Float         @default(0)
  status           TradeStatus   @default(OPEN)
  brokerOrderId    String?
  brokerConfirmed  Boolean       @default(false)
  agentDecisionId  String?
  agentDecision    AgentDecision? @relation(fields: [agentDecisionId], references: [id])
  openedAt         DateTime      @default(now())
  closedAt         DateTime?
  stopLossPrice    Float?
  takeProfitPrice  Float?
  exitReason       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([asset])
  @@index([status])
  @@index([openedAt])
}

enum TradeType {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
  FAILED
}

// AGENT DECISIONS
model AgentDecision {
  id              String   @id @default(cuid())
  asset           String
  signal          String
  finalVote       String
  totalVotes      Int
  goVotes         Int
  noGoVotes       Int
  avgConfidence   Float
  executed        Boolean  @default(false)
  executionReason String?
  agentVotes      Json
  marketSnapshot  Json
  timestamp       DateTime @default(now())
  trades          Trade[]

  @@index([asset])
  @@index([timestamp])
}

// OPEN POSITIONS
model Position {
  id             String   @id @default(cuid())
  asset          String   @unique
  market         String
  quantity       Float
  entryPrice     Float
  currentPrice   Float
  stopLossPrice  Float
  takeProfitPrice Float
  unrealizedPnl  Float    @default(0)
  unrealizedPnlPct Float  @default(0)
  status         String   @default("OPEN")
  openedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// PORTFOLIO SNAPSHOTS
model PortfolioSnapshot {
  id          String   @id @default(cuid())
  totalValue  Float
  cashBalance Float
  invested    Float
  pnlDay      Float    @default(0)
  pnlDayPct   Float    @default(0)
  pnlTotal    Float    @default(0)
  pnlTotalPct Float    @default(0)
  timestamp   DateTime @default(now())

  @@index([timestamp])
}

// NEWS FEED
model NewsItem {
  id              String   @id @default(cuid())
  headline        String
  source          String
  url             String?
  sentimentScore  Float
  sentimentLabel  String
  assetsMentioned String[]
  summary         String?
  publishedAt     DateTime
  createdAt       DateTime @default(now())

  @@index([publishedAt])
  @@index([assetsMentioned])
}

// DAILY JOURNAL
model DailyJournal {
  id           String   @id @default(cuid())
  date         String   @unique
  summary      String
  totalTrades  Int      @default(0)
  pnlDay       Float    @default(0)
  pnlDayPct    Float    @default(0)
  bestTrade    Json?
  worstTrade   Json?
  marketNotes  String?
  agentPerformance Json?
  createdAt    DateTime @default(now())
}

// FUTURE PREDICTIONS
model Prediction {
  id              String    @id @default(cuid())
  asset           String
  direction       String
  confidence      Float
  targetPrice     Float
  currentPrice    Float
  timeHorizon     String
  keyRisks        String[]
  wasCorrect      Boolean?
  resolvedAt      DateTime?
  resolvedPrice   Float?
  createdAt       DateTime  @default(now())

  @@index([asset])
  @@index([createdAt])
}

// MARKET EVENTS
model MarketEvent {
  id        String   @id @default(cuid())
  asset     String
  eventType String
  data      Json
  timestamp DateTime @default(now())

  @@index([asset])
  @@index([eventType])
  @@index([timestamp])
}

// SYSTEM LOGS
model SystemLog {
  id        String   @id @default(cuid())
  level     String
  service   String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([level])
  @@index([service])
  @@index([timestamp])
}

// AGENT CONVERSATIONS (Agent Chat System)
model AgentConversation {
  id              String   @id @default(cuid())
  agentId         String
  agentName       String
  userMessage     String
  agentResponse   String
  context         Json?
  sessionId       String?
  reactions       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agentId])
  @@index([createdAt])
  @@index([sessionId])
}

// AGENT LESSONS (Self-Learning System)
model AgentLesson {
  id              String   @id @default(cuid())
  agentId         String
  agentName       String
  asset           String
  setupType       String
  prediction      String
  outcome         String
  correct         Boolean
  reasoning       String
  confidenceScore Float
  newWeighting    Float
  tradeId         String?
  performanceImpact Float
  createdAt       DateTime @default(now())

  @@index([agentId])
  @@index([asset])
  @@index([setupType])
  @@index([createdAt])
}

// AGENT PERFORMANCE SUMMARY
model AgentPerformance {
  id                String   @id @default(cuid())
  agentId           String   @unique
  agentName         String
  totalTrades       Int      @default(0)
  winRate           Float    @default(0)
  accuracy          Float    @default(0)
  profitFactor      Float    @default(1)
  sharpRatio        Float    @default(0)
  maxDrawdown       Float    @default(0)
  avgConfidence     Float    @default(0)
  lessonsLearned    Int      @default(0)
  status            String   @default("ACTIVE")
  suspendedAt       DateTime?
  lastUpdated       DateTime @default(now()) @updatedAt
  weeklyReport      Json?

  @@index([agentId])
  @@index([status])
}

// AGENT ADJUSTMENTS (Owner-made tweaks)
model AgentAdjustment {
  id              String   @id @default(cuid())
  agentId         String
  agentName       String
  adjustmentType  String
  description     String
  beforeValue     String
  afterValue      String
  reason          String
  appliedAt       DateTime @default(now())
  effectiveness   Float?
  createdAt       DateTime @default(now())

  @@index([agentId])
  @@index([appliedAt])
}

// LEARNING RESOURCES (External data that agents learn from)
model LearningResource {
  id                String   @id @default(cuid())
  type              String   // 'news', 'fundamental', 'macro', 'on_chain'
  asset             String
  title             String
  content           String
  sentiment         String   // 'bullish', 'bearish', 'neutral'
  sentimentScore    Float    // -1 to 1
  confidence        Float    // 0 to 1
  source            String
  relevanceScore    Float
  metadata          Json?
  timestamp         DateTime @default(now())
  expiresAt         DateTime?
  createdAt         DateTime @default(now())

  @@index([type])
  @@index([asset])
  @@index([sentiment])
  @@index([timestamp])
}

// GEOPOLITICAL EVENTS
model GeopoliticalEvent {
  id                String   @id @default(cuid())
  title             String
  description       String
  eventType         String   // 'sanctions', 'regulation', 'war', 'election', 'trade', 'policy', 'natural_disaster'
  severity          Int      // 1-10 scale
  countries         String[]
  affectedAssets    String[]
  geoRiskScore      Float    // 0-100
  impactDuration    String
  marketImpact      String   // 'negative', 'positive', 'neutral'
  source            String
  timestamp         DateTime @default(now())
  followUpRequired  Boolean  @default(false)
  metadata          Json?
  createdAt         DateTime @default(now())

  @@index([eventType])
  @@index([geoRiskScore])
  @@index([timestamp])
}

// MACRO INDICATORS
model MacroIndicator {
  id                String   @id @default(cuid())
  name              String   // 'FED_RATE', 'INFLATION', 'UNEMPLOYMENT', 'VIX', 'USD_EUR', etc
  value             Float
  previousValue     Float?
  unit              String
  importance        String   // 'critical', 'high', 'medium', 'low'
  direction         String   // 'up', 'down', 'stable'
  source            String
  lastUpdated       DateTime
  nextRelease       DateTime?
  expectedValue     Float?
  impact            String   // 'bullish', 'bearish', 'neutral'
  notes             String?
  createdAt         DateTime @default(now())

  @@index([name])
  @@index([importance])
  @@index([lastUpdated])
}

// AGENT LEARNING STATE (Snapshot of learning for specific asset)
model AgentLearningState {
  id                String   @id @default(cuid())
  agentId           String
  assetId           String
  fundamentalScore  Float    // 0-100
  technicalScore    Float    // 0-100
  sentimentScore    Float    // 0-100
  riskScore         Float    // 0-100
  confidenceAdjustment Float
  overallScore      Float    // 0-100, weighted combination
  learningSources   Json     // { news: [...], fundamentals: [...], macro: [...], onChain: [...] }
  recommendations   String   // 'BUY', 'SELL', 'HOLD'
  lastUpdated       DateTime @default(now())
  createdAt         DateTime @default(now())

  @@unique([agentId, assetId])
  @@index([agentId])
  @@index([assetId])
  @@index([overallScore])
}

// COMPANY FUNDAMENTALS (Phase 2 - fetched from Polygon.io weekly)
model CompanyFundamentals {
  id                String   @id @default(cuid())
  symbol            String   @unique
  name              String?
  sector            String?
  industry          String?
  marketCap         Float?
  peRatio           Float?
  pbRatio           Float?
  psRatio           Float?
  revenueGrowthYoy  Float?
  epsGrowthYoy      Float?
  grossMargin       Float?
  operatingMargin   Float?
  netMargin         Float?
  debtToEquity      Float?
  currentRatio      Float?
  dividendYield     Float?
  beta              Float?
  week52High        Float?
  week52Low         Float?
  avgVolume         Float?
  sharesOutstanding Float?
  insiderOwnership  Float?
  institutionalOwnership Float?
  analystRating     String?   // 'STRONG_BUY','BUY','HOLD','SELL','STRONG_SELL'
  analystTargetPrice Float?
  nextEarningsDate  DateTime?
  lastUpdated       DateTime  @default(now())
  createdAt         DateTime  @default(now())

  @@index([symbol])
  @@index([sector])
  @@index([marketCap])
}

// ANNUAL REPORTS - key metrics from 10-K filings (Phase 3)
model AnnualReport {
  id              String   @id @default(cuid())
  symbol          String
  year            Int
  revenue         Float?
  netIncome       Float?
  eps             Float?
  freeCashFlow    Float?
  totalDebt       Float?
  totalAssets     Float?
  totalEquity     Float?
  revenueGrowth   Float?
  netIncomeGrowth Float?
  epsGrowth       Float?
  dividendPaid    Float?
  sharesBuyback   Float?
  source          String   @default("fmp")
  createdAt       DateTime @default(now())

  @@unique([symbol, year])
  @@index([symbol])
  @@index([year])
}

// STOCK MEMORY - self-learning per stock per agent (Phase 4)
model StockMemory {
  id              String   @id @default(cuid())
  symbol          String
  totalDebates    Int      @default(0)
  totalTrades     Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  winRate         Float    @default(0)
  avgPnlPct       Float    @default(0)
  bestSetup       String?
  worstSetup      String?
  avgHoldHours    Float    @default(0)
  lastDebateVote  String?
  lastTradeOutcome String?
  keyLessons      String[] @default([])
  avoidConditions String[] @default([])
  favorConditions String[] @default([])
  lastUpdated     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([symbol])
  @@index([symbol])
  @@index([winRate])
}

// GEO RISK ASSESSMENT (Summary of global risk)
model GeoRiskAssessment {
  id                String   @id @default(cuid())
  timestamp         DateTime @default(now())
  overallRisk       Int      // 0-100
  geoRisk           Int      // 0-100
  policyRisk        Int      // 0-100
  marketRisk        Int      // 0-100
  activeEvents      Int      // Number of active events
  tradingMode       String   // 'aggressive', 'balanced', 'conservative', 'hibernation'
  recommendations   String   // Trading advice based on risk
  criticalEvents    Json?    // Array of events triggering high risk
  metadata          Json?
  createdAt         DateTime @default(now())

  @@index([timestamp])
  @@index([overallRisk])
}
