// APEX TRADER — Prisma Database Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── OWNER AUTH ───────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  lastLogin    DateTime?
  sessionToken String?
  ipWhitelist  String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── TRADES ───────────────────────────────────────────────────────────────────
model Trade {
  id               String        @id @default(cuid())
  asset            String        // e.g. BTC, AAPL
  market           String        // crypto | stocks | forex
  type             TradeType
  entryPrice       Float
  exitPrice        Float?
  quantity         Float
  pnl              Float?        // in dollars
  pnlPct           Float?        // in percentage
  fees             Float         @default(0)
  status           TradeStatus   @default(OPEN)
  brokerOrderId    String?
  brokerConfirmed  Boolean       @default(false)
  agentDecisionId  String?
  agentDecision    AgentDecision? @relation(fields: [agentDecisionId], references: [id])
  openedAt         DateTime      @default(now())
  closedAt         DateTime?
  stopLossPrice    Float?
  takeProfitPrice  Float?
  exitReason       String?       // stop_loss | take_profit | agent_signal | kill_switch | manual
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([asset])
  @@index([status])
  @@index([openedAt])
}

enum TradeType {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
  FAILED
}

// ── AGENT DECISIONS ──────────────────────────────────────────────────────────
model AgentDecision {
  id              String   @id @default(cuid())
  asset           String
  signal          String   // BUY | SELL | HOLD
  finalVote       String   // BUY | SELL | HOLD
  totalVotes      Int
  goVotes         Int
  noGoVotes       Int
  avgConfidence   Float
  executed        Boolean  @default(false)
  executionReason String?
  agentVotes      Json     // Array of 10 agent vote objects
  marketSnapshot  Json     // Price data at decision time
  timestamp       DateTime @default(now())
  trades          Trade[]

  @@index([asset])
  @@index([timestamp])
}

// ── OPEN POSITIONS ───────────────────────────────────────────────────────────
model Position {
  id             String   @id @default(cuid())
  asset          String   @unique
  market         String
  quantity       Float
  entryPrice     Float
  currentPrice   Float
  stopLossPrice  Float
  takeProfitPrice Float
  unrealizedPnl  Float    @default(0)
  unrealizedPnlPct Float  @default(0)
  status         String   @default("OPEN")  // OPEN | CLOSED
  openedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ── PORTFOLIO SNAPSHOTS ──────────────────────────────────────────────────────
model PortfolioSnapshot {
  id          String   @id @default(cuid())
  totalValue  Float
  cashBalance Float
  invested    Float
  pnlDay      Float    @default(0)
  pnlDayPct   Float    @default(0)
  pnlTotal    Float    @default(0)
  pnlTotalPct Float    @default(0)
  timestamp   DateTime @default(now())

  @@index([timestamp])
}

// ── NEWS FEED ─────────────────────────────────────────────────────────────────
model NewsItem {
  id              String   @id @default(cuid())
  headline        String
  source          String
  url             String?
  sentimentScore  Float    // -1 to 1
  sentimentLabel  String   // POSITIVE | NEGATIVE | NEUTRAL
  assetsMentioned String[]
  summary         String?
  publishedAt     DateTime
  createdAt       DateTime @default(now())

  @@index([publishedAt])
  @@index([assetsMentioned])
}

// ── DAILY JOURNAL ─────────────────────────────────────────────────────────────
model DailyJournal {
  id           String   @id @default(cuid())
  date         String   @unique  // YYYY-MM-DD
  summary      String   // AI-generated full summary
  totalTrades  Int      @default(0)
  pnlDay       Float    @default(0)
  pnlDayPct    Float    @default(0)
  bestTrade    Json?    // { asset, pnl, reasoning }
  worstTrade   Json?    // { asset, pnl, reasoning }
  marketNotes  String?
  agentPerformance Json? // Which agents were most accurate
  createdAt    DateTime @default(now())
}

// ── FUTURE PREDICTIONS ────────────────────────────────────────────────────────
model Prediction {
  id              String    @id @default(cuid())
  asset           String
  direction       String    // UP | DOWN | SIDEWAYS
  confidence      Float
  targetPrice     Float
  currentPrice    Float
  timeHorizon     String    // 1h | 4h | 1D | 1W
  keyRisks        String[]
  wasCorrect      Boolean?
  resolvedAt      DateTime?
  resolvedPrice   Float?
  createdAt       DateTime  @default(now())

  @@index([asset])
  @@index([createdAt])
}

// ── MARKET EVENTS ─────────────────────────────────────────────────────────────
model MarketEvent {
  id        String   @id @default(cuid())
  asset     String
  eventType String   // PRICE_ALERT | VOLUME_SPIKE | PATTERN_DETECTED | NEWS | GUARDRAIL_TRIGGER
  data      Json
  timestamp DateTime @default(now())

  @@index([asset])
  @@index([eventType])
  @@index([timestamp])
}

// ── SYSTEM LOGS ───────────────────────────────────────────────────────────────
model SystemLog {
  id        String   @id @default(cuid())
  level     String   // INFO | WARN | ERROR | CRITICAL
  service   String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([level])
  @@index([service])
  @@index([timestamp])
}

// ── AGENT CONVERSATIONS (Agent Chat System) ──────────────────────────────────
model AgentConversation {
  id              String   @id @default(cuid())
  agentId         String   // Which agent (e.g. "technician", "risk_manager", etc)
  agentName       String   // Human-readable agent name
  userMessage     String   // User's question or instruction
  agentResponse   String   // Claude's response as that agent
  context         Json?    // Market data, agent votes, portfolio state at conversation time
  sessionId       String?  // Group related conversations
  reactions       Int      @default(0)  // User can thumbs-up helpful responses
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agentId])
  @@index([createdAt])
  @@index([sessionId])
}

// ── AGENT LESSONS (Self-Learning System) ──────────────────────────────────────
model AgentLesson {
  id              String   @id @default(cuid())
  agentId         String   // Which agent learned
  agentName       String   // Human-readable name
  asset           String   // BTC, ETH, AAPL, etc
  setupType       String   // Technical pattern or strategy name
  prediction      String   // What agent predicted (BUY | SELL | HOLD)
  outcome         String   // What actually happened
  correct         Boolean  // Was the prediction right?
  reasoning       String   // Why was it right/wrong? (Claude-generated)
  confidenceScore Float    // Agent's confidence (0-1) on this setup
  newWeighting    Float    // Updated weight for future decisions
  tradeId         String?  // Link to Trade if this resulted in an executed trade
  performanceImpact Float  // How much this affected P&L compared to expectancy
  createdAt       DateTime @default(now())

  @@index([agentId])
  @@index([asset])
  @@index([setupType])
  @@index([createdAt])
}

// ── AGENT PERFORMANCE SUMMARY ──────────────────────────────────────────────────
model AgentPerformance {
  id                String   @id @default(cuid())
  agentId           String   @unique // One record per agent
  agentName         String
  totalTrades       Int      @default(0)
  winRate           Float    @default(0) // percentage 0-100
  accuracy          Float    @default(0) // percentage 0-100
  profitFactor      Float    @default(1) // total wins / total losses
  sharpRatio        Float    @default(0)
  maxDrawdown       Float    @default(0) // worst peak-to-trough
  avgConfidence     Float    @default(0) // average confidence on votes
  lessonsLearned    Int      @default(0) // count of post-trade lessons
  status            String   @default("ACTIVE") // ACTIVE | SUSPENDED | RECALIBRATING
  suspendedAt       DateTime? // When it was suspended for poor performance
  lastUpdated       DateTime @default(now()) @updatedAt
  weeklyReport      Json?    // JSON summary from last Sunday review

  @@index([agentId])
  @@index([status])
}

// ── AGENT ADJUSTMENTS (Owner-made tweaks) ──────────────────────────────────────
model AgentAdjustment {
  id              String   @id @default(cuid())
  agentId         String
  agentName       String
  adjustmentType  String   // CONFIDENCE_WEIGHT | STRATEGY_FOCUS | ASSET_FOCUS | POSITION_SIZE
  description     String
  beforeValue     String   // JSON of old settings
  afterValue      String   // JSON of new settings
  reason          String   // Why owner made the change
  appliedAt       DateTime @default(now())
  effectiveness   Float?   // In percentage - how much it improved P&L
  createdAt       DateTime @default(now())

  @@index([agentId])
  @@index([appliedAt])
}
